[Unit]
Description=Google Drive (rclone)
StartLimitIntervalSec=60s
StartLimitBurst=3

[Service]
Type=simple
ExecStart=rclone mount gdrive: %h/Drive \
  --vfs-cache-mode full \
  --vfs-cache-max-size 20G \
  --vfs-read-ahead 128M \
  --buffer-size 256M \
  --poll-interval 30s
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
